{
  "version": "1.0.0",
  "profile": "production",
  "testRunner": "node --test",
  "deployTarget": "github-actions",
  "ship": {
    "deploy": {
      "type": "ci-dispatch",
      "workflow": "pages.yml",
      "ref": "main",
      "timeoutSec": 600,
      "healthUrl": "https://apurvbazari.github.io/matali-fullpipeline-dogfood/"
    },
    "smoke": {
      "cmd": "curl -fsSL \"https://apurvbazari.github.io/matali-fullpipeline-dogfood/\" | grep -qi password"
    },
    "rollback": {
      "cmd": "gh workflow run pages.yml --ref main"
    },
    "merge": {
      "strategy": "squash"
    },
    "driveThrough": true
  },
  "maintain": {
    "checks": [],
    "disableBuiltins": [],
    "loopback": {
      "autoFixMaxSeverity": "low"
    }
  },
  "ux": {
    "watch": {
      "offerAtStart": true,
      "cadence": "per-profile"
    },
    "statusline": {
      "idleGlyph": true
    }
  },
  "createdAt": "2026-06-24T05:00:04Z"
}
